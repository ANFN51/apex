# ============================================================
#  Apex Realty Centers — Apache Security Configuration
# ============================================================

# ── Disable directory listing ─────────────────────────────
Options -Indexes -ExecCGI

# ── Hide Apache version & OS ──────────────────────────────
ServerSignature Off

# ── Block access to sensitive files ───────────────────────
<FilesMatch "(^\.htaccess|^\.env|^db\.php|\.sql$|\.log$|\.bak$|\.git)">
    Require all denied
</FilesMatch>

# ── Security Headers ──────────────────────────────────────
<IfModule mod_headers.c>
    # Prevent MIME-type sniffing
    Header always set X-Content-Type-Options "nosniff"

    # Prevent clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"

    # XSS Protection (legacy browsers)
    Header always set X-XSS-Protection "1; mode=block"

    # Control referrer info sent to third-party pages
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Restrict browser features  
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=(), interest-cohort=()"

    # Content Security Policy
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' blob: https://cdn.jsdelivr.net https://unpkg.com https://fonts.googleapis.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://unpkg.com https://fonts.googleapis.com https://fonts.gstatic.com; font-src 'self' https://fonts.gstatic.com https://cdn.jsdelivr.net; img-src 'self' data: blob: https:; frame-src https://www.google.com; connect-src 'self' blob: https://formspree.io; worker-src 'self' blob:; child-src 'self' blob:; object-src 'none'; base-uri 'self'; form-action 'self' https://formspree.io;"

    # HTTP Strict Transport Security (uncomment when HTTPS is live)
    # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # Remove server info from responses
    Header always unset X-Powered-By
    Header always unset Server
</IfModule>

# ── Block common attack patterns in URLs ──────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block SQL injection attempts in query strings
    RewriteCond %{QUERY_STRING} (union|select|insert|drop|delete|update|cast|create|char|convert|alter|exec|script) [NC]
    RewriteRule .* - [F,L]

    # Block path traversal attempts
    RewriteCond %{REQUEST_URI} \.\./  [NC]
    RewriteRule .* - [F,L]

    # Block null bytes
    RewriteCond %{QUERY_STRING} \0 [NC]
    RewriteRule .* - [F,L]

    # Block XSS attempts in URL
    RewriteCond %{QUERY_STRING} (<|%3C).*script.*(>|%3E) [NC]
    RewriteRule .* - [F,L]

    # Block bad bots
    RewriteCond %{HTTP_USER_AGENT} (masscan|nikto|sqlmap|nmap|havij|acunetix|openvas|nessus|metasploit) [NC]
    RewriteRule .* - [F,L]
</IfModule>

# ── Limit request methods ─────────────────────────────────
<LimitExcept GET POST HEAD>
    Require all denied
</LimitExcept>

# ── Prevent hotlinking of images ──────────────────────────
<IfModule mod_rewrite.c>
    RewriteCond %{HTTP_REFERER} !^$
    RewriteCond %{HTTP_REFERER} !^https?://(www\.)?apexrealtycenters\.com [NC]
    RewriteCond %{HTTP_REFERER} !^https?://localhost [NC]
    RewriteRule \.(jpg|jpeg|png|gif|webp|svg)$ - [F,L]
</IfModule>

# ── PHP security settings (if PHP is loaded via Apache) ───
<IfModule mod_php.c>
    php_flag display_errors Off
    php_flag log_errors On
    php_flag expose_php Off
    php_value session.cookie_httponly 1
    php_value session.cookie_samesite Strict
    php_value session.use_strict_mode 1
    php_value session.gc_maxlifetime 1800
</IfModule>

# ── Compression (gzip all text assets) ───────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/x-javascript
    AddOutputFilterByType DEFLATE application/json application/xml
    AddOutputFilterByType DEFLATE image/svg+xml
    SetEnvIfNoCase Request_URI \.(?:gif|jpe?g|png|webp|woff2?)$ no-gzip dont-vary
</IfModule>

# ── Browser Caching (aggressive) ─────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 week"
    ExpiresByType image/jpeg             "access plus 6 months"
    ExpiresByType image/png              "access plus 6 months"
    ExpiresByType image/webp             "access plus 6 months"
    ExpiresByType image/svg+xml          "access plus 6 months"
    ExpiresByType font/woff2             "access plus 6 months"
    ExpiresByType application/font-woff2 "access plus 6 months"
    ExpiresByType text/css               "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
    ExpiresByType text/html              "access plus 2 hours"
</IfModule>

# ── Cache-Control immutable for fingerprinted assets ──────
<IfModule mod_headers.c>
    <FilesMatch "\.(css|js)$">
        Header append Vary Accept-Encoding
    </FilesMatch>
    <FilesMatch "\.(woff2?|png|jpg|jpeg|webp|gif|svg)$">
        Header append Cache-Control "immutable"
    </FilesMatch>
    Header unset ETag
    FileETag None
</IfModule>

# ── 3D Model MIME Types ──────────────────────────────────
<IfModule mod_mime.c>
    AddType model/gltf-binary .glb
    AddType model/gltf+json .gltf
</IfModule>
